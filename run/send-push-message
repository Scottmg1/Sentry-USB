#!/bin/bash -eu

title="$1"
message="$2"
type="${3:-}"
notification_type="${4:-}"

# Helper: run curl and check the HTTP status code. Logs errors with response body.
# Usage: checked_curl "ServiceName" curl_args...
function checked_curl () {
  local service="$1"; shift
  local response http_code body
  response=$(curl -s -w "\n%{http_code}" "$@") || {
    log "ERROR: $service — curl failed (exit code $?)"
    return 1
  }
  http_code=$(echo "$response" | tail -1)
  body=$(echo "$response" | sed '$d')
  if [ "$http_code" -lt 200 ] 2>/dev/null || [ "$http_code" -ge 300 ] 2>/dev/null; then
    log "ERROR: $service — HTTP $http_code — $body"
    return 1
  fi
}

function send_signal () {
  log "Sending Signal message."

  checked_curl "Signal" -X POST -H "Content-Type: application/json" "$SIGNAL_URL/v2/send" \
     -d '{"message": "'"$message"'", "number": "'"$SIGNAL_FROM_NUM"'", "recipients": [ "'"$SIGNAL_TO_NUM"'" ]}'
}

function send_pushover () {
  log "Sending Pushover message."

  checked_curl "Pushover" \
    -F "token=$PUSHOVER_APP_KEY" \
    -F "user=$PUSHOVER_USER_KEY" \
    -F "title=$title" \
    -F "message=$message" \
    https://api.pushover.net/1/messages
}

function send_gotify () {
  log "Sending Gotify message."

  checked_curl "Gotify" -X POST \
    -F "title=$title" \
    -F "message=$message" \
    -F "priority=$GOTIFY_PRIORITY" \
    "$GOTIFY_DOMAIN/message?token=$GOTIFY_APP_TOKEN"
}

function send_discord() {
  log "Sending Discord message."

  checked_curl "Discord" -H "Content-Type: application/json" -d \
    '{"username": "'"$title"'", "content": "'"$message"'"}' \
    "$DISCORD_WEBHOOK_URL"
}

function send_ifttt () {
  log "Sending IFTTT message."

  checked_curl "IFTTT" -X POST -H "Content-Type: application/json" -d \
    '{"value1":"'"$title"'","value2":"'"$message"'"}' \
    "https://maker.ifttt.com/trigger/$IFTTT_EVENT_NAME/with/key/$IFTTT_KEY"
}

function send_sns () {
  log "Sending SNS message."

  if ! python3 /root/bin/send_sns.py -t "$AWS_SNS_TOPIC_ARN" -s "$title" -m "$message"; then
    log "ERROR: SNS — python script failed (exit code $?)"
  fi
}

function send_matrix() {
  log "Send Matrix message."

  if ! python3 /root/bin/send_matrix.py "$MATRIX_SERVER_URL" "$MATRIX_USERNAME" "$MATRIX_PASSWORD" "$MATRIX_ROOM" "$title: $message"; then
    log "ERROR: Matrix — python script failed (exit code $?)"
  fi
}

function send_telegram () {
  log "Sending Telegram message."
  checked_curl "Telegram" -H "Content-Type: application/json" -d \
    '{"chat_id": "'"$TELEGRAM_CHAT_ID"'", "text": "'"$title: $message"'", "disable_notification": '"$TELEGRAM_SILENT_NOTIFY"' }' \
    https://api.telegram.org/"$TELEGRAM_BOT_TOKEN"/sendMessage
}

function send_webhook () {
  log "Sending Webhook message."

  checked_curl "Webhook" -X POST \
    -d "{\"value1\":\"${title}\",\"value2\":\"${message}\"}" \
    -H "Content-Type: application/json" \
    "$WEBHOOK_URL"
}

function send_slack () {
  log "Sending Slack message."
  payload="{\"text\":\"$title: $message\",\"username\": \"Tesla\",\"icon_emoji\": \":tesla:\"}"
  checked_curl "Slack" -X POST --data-urlencode "payload=$payload" "$SLACK_WEBHOOK_URL"
}

function send_ntfy () {
  log "Sending ntfy message."

  checked_curl "ntfy" -X POST \
    -H "Title: $title" \
    -H "Priority: ${NTFY_PRIORITY:-3}" \
    ${NTFY_TOKEN:+-H "Authorization: Bearer $NTFY_TOKEN"} \
    -d "$message" \
    "$NTFY_URL"
}

function send_mobile_push () {
  log "Sending mobile push notification."

  local payload="{\"title\":\"${title}\",\"message\":\"${message}\",\"device_id\":\"${MOBILE_PUSH_DEVICE_ID}\""
  if [ -n "$notification_type" ]; then
    payload+=",\"notification_type\":\"${notification_type}\""
  fi
  # For archive start notifications, include live_activity data so the visible
  # notification also wakes the app to create the Live Activity (more reliable
  # than silent push for terminated apps)
  if [ "$type" = "start" ] && [ "$notification_type" = "archive" ] && [ -n "${ARCHIVE_TOTAL_COUNT:-}" ]; then
    local device_name="${title%:}"
    payload+=",\"live_activity\":{\"action\":\"start\",\"phase\":\"archiving\",\"current\":0,\"total\":${ARCHIVE_TOTAL_COUNT},\"device_name\":\"${device_name}\"}"
  fi
  payload+="}"

  checked_curl "Mobile Push" -X POST \
    -H "Content-Type: application/json" \
    -H "X-Device-Secret: $MOBILE_PUSH_SECRET" \
    -d "$payload" \
    "https://notifications.sentry-six.com/send"
}

function send_shell () {
  log "Sending Shell command."
  if [[ -n "$NOTIFICATION_COMMAND_START" && "$type" = "start" ]]; then
    eval "$NOTIFICATION_COMMAND_START" &
  fi
  if [[ -n "$NOTIFICATION_COMMAND_FINISH" &&  "$type" = "finish" ]]; then
    eval "$NOTIFICATION_COMMAND_FINISH" &
  fi
}

log "$message"

[ "${SIGNAL_ENABLED:-false}" = "true" ] && send_signal
[ "${PUSHOVER_ENABLED:-false}" = "true" ] && send_pushover
[ "${GOTIFY_ENABLED:-false}" = "true" ] && send_gotify
[ "${DISCORD_ENABLED:-false}" = "true" ] && send_discord
[ "${IFTTT_ENABLED:-false}" = "true" ] && send_ifttt
[ "${SNS_ENABLED:-false}" = "true" ] && send_sns
[ "${WEBHOOK_ENABLED:-false}" = "true" ] && send_webhook
[ "${TELEGRAM_ENABLED:-false}" = "true" ] && send_telegram
[ "${MATRIX_ENABLED:-false}" = "true" ] && send_matrix
[ "${SLACK_ENABLED:-false}" = "true" ] && send_slack
[ "${NTFY_ENABLED:-false}" = "true" ] && send_ntfy
[ "${MOBILE_PUSH_ENABLED:-false}" = "true" ] && send_mobile_push
[ "${NOTIFICATION_COMMAND_ENABLED:-false}" = "true" ] && send_shell

exit 0
